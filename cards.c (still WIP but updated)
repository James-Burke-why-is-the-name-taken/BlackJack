#include <stdio.h>
#include <stdlib.h>
#include <time.h>

const char *suits[4] = {"Clubs", "Diamonds", "Spades", "Hearts"};

const char *values[13] = {"Ace", "2", "3", "4", "5", "6", "7", "8", "9", "10", "Jack", "Queen", "King"};


typedef struct Card{
        int suit;
        int value;
        int dealt; // 104 card deck, so if dealt = 2, dont draw it.
}Card;

typedef struct hand{
        Card held[10];
        int amount;
}hand;

void create(Card deck[]){
        int s;
        int v;
        int i = 0;
        for (s=0;s<4;s++){
                for (v=0;v<13;v++){
                        deck[i].suit = s;
                        deck[i].value = v;
                        deck[i].dealt = 0;
                        i++;
                }
        }
}

int draw(Card deck[]){

        int i;
        int count = 0;
        i = rand() % 52;
        while (deck[i].dealt == 2){
                i = rand()% 52;
                count++;
                if (count == 104){
                        create(deck);
                        printf("Deck has been re shuffled.");
                        }
                }
        deck[i].dealt++;
        return i;
        }

void print(Card deck[]){
        int r;
        r = draw(deck);
        printf("Card suit: %s Card Value: %s \n", suits[deck[r].suit], values[deck[r].value]);
        }

void add_to_hand(int num, hand *held, Card deck[]){
        held->held[held->amount] = deck[num];
        held->amount++;
        }

int scoring(hand held){
        int aces = 0;
        int total_score = 0;
        int i;

        for (i=0; i<held.amount;i++){
                int value= held.held[i].value;

                if (value == 0){
                        total_score += 11;
                        aces++;
                        }
                else if (value >= 10){
                        total_score += 10;
                        }
                else {
                        total_score += (value +1);
                        }
                }
        while (total_score >21 && aces > 0){
                total_score -=10;
                aces--;
                }
        return total_score;
        }

void print_dealer_hand(hand held){
        printf("Dealer's hand:\n");
        int i;
        for (i=0; i<held.amount;i++){
                printf("%s of %s ", values[held.held[i].value], suits[held.held[i].suit]);
                }
        printf("Their score: %d\n", scoring(held));
        }

void print_player_hand(hand held){
        printf("Your hand:\n");
        int i;
        for (i=0; i <held.amount;i++){
                printf("%s of %s ", values[held.held[i].value], suits[held.held[i].suit]);
                }
        printf("Your score: %d\n", scoring(held));
        }

