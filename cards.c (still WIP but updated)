        }
else { //also added after most of the code was done.
printf("Dealer's turn.\n");
while (scoring(dealer) < 17){
        add_to_hand(draw(deck), &dealer, deck);
        }
print_dealer_hand(dealer);
dscore = scoring(dealer);

if (dscore > 21 || pscore > dscore){
