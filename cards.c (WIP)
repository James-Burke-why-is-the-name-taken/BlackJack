void create(Card deck[]){
        int s;
        int v;
        int i = 0;
        for (s=0;s<4;s++){
                for (v=0;v<13;v++){
                        deck[i].suit = s;
                        deck[i].value = v;
                        deck[i].dealt = 0;
                        i++;
                }
        }
}

int draw(Card deck[]){

        int i;
        int count = 0;
        i = rand() % 52;
        while (deck[i].dealt == 2){
                i = rand()% 52;
                count++;
                if (count == 104){
                        create(deck);
                        printf("Deck has been re shuffled.");
                        }
                }
        deck[i].dealt++;
        return i;
        }

void print(Card deck[]){
        int r;
        r = draw(deck);
        printf("Card suit: %s Card Value: %s \n", suits[deck[r].suit], values[deck[r].value]);
        }

